# ────────────────────────────────────────────────────────────
# このファイルを .env.local にコピーしてから値を埋めてください
# Netlify にデプロイする場合は Netlify ダッシュボードの
# Site settings → Environment variables に同じキーを登録してください
# ────────────────────────────────────────────────────────────

# Google Maps JavaScript API キー
# https://console.cloud.google.com/ で取得
# 有効にするAPI: Maps JavaScript API
VITE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# Firebase 設定
# Firebase Console → プロジェクトの設定 → マイアプリ → ウェブアプリ から取得
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://YOUR_PROJECT_ID-default-rtdb.asia-southeast1.firebasedatabase.app
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
